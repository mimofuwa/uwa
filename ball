<style>
.magic-ball { width: 120px; height: 120px; background: radial-gradient(circle at 30% 30%, #444, #000); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 10px 10px rgba(0,0,0,0.8); transition: transform 0.1s; }
.magic-ball:active { transform: translateY(5px); }
.magic-window { width: 60px; height: 60px; background: #000; border-radius: 50%; border: 3px solid #222; display: flex; align-items: center; justify-content: center; position: relative; }
.magic-triangle { width: 0; height: 0; border-left: 22px solid transparent; border-right: 22px solid transparent; border-top: 38px solid #000080; position: absolute; z-index: 1; }
.magic-ans { color: #fff; font-family: sans-serif; font-size: 9px; z-index: 2; text-align: center; position: absolute; top: 14px; font-weight: bold; width: 35px; line-height: 10px;}
</style>
<div class="magic-ball" onclick="shakeBall()">
  <div class="magic-window">
    <div class="magic-triangle"></div>
    <div class="magic-ans" id="ball-text">ASK<br>ME</div>
  </div>
</div>
<script>
  const answers = ['YES', 'NO', 'MAYBE', 'LATER', 'NO WAY', 'SURE', 'BAD<br>IDEA', 'TRY<br>AGAIN'];
  function shakeBall() {
    document.getElementById('ball-text').innerHTML = answers[Math.floor(Math.random() * answers.length)];
  }
</script>
<img src="https://sweetembed.neocities.org/se_spacer.png" alt="" width="1" height="1" style="position:absolute; visibility:hidden;">
